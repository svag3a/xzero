# AWS Bedrock (Claude API)
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=eu-north-1

# Tavily (web search in opportunity scan)
TAVILY_API_KEY=tvly-...

# Fireflies (meeting transcripts)
FIREFLIES_API_KEY=...

# Data directory (default: current dir; Docker: /data)
DATA_DIR=/data
